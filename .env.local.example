# ─────────────────────────────────────────────────────────────────────────────
# OHIRO LEDGER — variáveis de ambiente para desenvolvimento local
#
# Copie este arquivo para `.env.local` e preencha com suas chaves reais:
#
#   cp .env.local.example .env.local
#
# `.env.local` já está no .gitignore (regra `.env*.local`) — o Next.js carrega
# esse arquivo automaticamente em `pnpm dev`, e ele NUNCA é commitado nem vai
# para o `main`. Suas chaves reais ficam só na sua máquina.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (obrigatório para login/dados) ──────────────────────────────────
# Pegue em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — só se for rodar funções administrativas localmente.
# NUNCA exponha esta chave no client (sem NEXT_PUBLIC_).
SUPABASE_SECRET_KEY=

# ── Providers de IA (todos opcionais — configure só os que for testar) ───────
# O roteador em app/api/ai/chat/route.ts cai automaticamente para o próximo
# provider configurado, então você pode ativar 1, alguns ou todos.

# Gemini — free tier generoso, é o provider padrão
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free tier, não suporta arquivos
# https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — pago por token
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — pago por token
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
